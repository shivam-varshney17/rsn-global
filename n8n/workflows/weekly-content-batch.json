              "value": "=[{\"role\":\"system\",\"content\":\"You write Twitter/X posts. Short, punchy, no arrow bullets, no emoji steps, no repost asks. Keep it under 280 chars or write a concise long-form post. Native Twitter voice.\"},{\"role\":\"user\",\"content\":\"Generate a Twitter post for: {{ $json.core_idea }}\"}]"
