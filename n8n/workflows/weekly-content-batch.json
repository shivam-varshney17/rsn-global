        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "MiniMax-Text-01"
            },
            {
              "name": "messages",
              "value": "=[{\"role\":\"system\",\"content\":\"You are Aryan Mahajan. Write LinkedIn posts using em dashes, arrow bullets, hype adjectives, binary closers. Voice: confident, technical, authoritative. Use the Replacement Stack skeleton: 'This [thing] replaces your $[X] [role].'\"},{\"role\":\"user\",\"content\":\"Generate a LinkedIn post for: {{ $json.core_idea }}\"}]"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
